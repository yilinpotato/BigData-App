<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!-- 单节点：副本数=1，指定 namenode/datanode 落盘目录 -->
<configuration>
  <property>
    <name>dfs.replication</name>
    <value>1</value>
  </property>
  <property>
    <name>dfs.namenode.name.dir</name>
    <value>/home/qqrtq/hadoopdata/nn</value>
  </property>
  <property>
    <name>dfs.datanode.data.dir</name>
    <value>/home/qqrtq/hadoopdata/dn</value>
  </property>
  <property>
    <name>dfs.permissions.enabled</name>
    <value>false</value>
  </property>
</configuration>
